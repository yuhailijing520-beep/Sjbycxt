# ============================================================
# WorldCup Oracle — 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 运行环境 ─────────────────────────────────────────────────
# development | production
ENVIRONMENT=development

# 允许跨域来源（多个用逗号分隔；production 建议填写实际域名）
# 例如: https://your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=*

# ── AI 模型配置 ──────────────────────────────────────────────
# 选择 AI 提供商: gemini | openai
AI_PROVIDER=gemini

# Google Gemini API Key（免费额度较多，推荐）
# 申请地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini 模型名（可选）
GEMINI_MODEL=gemini-pro

# OpenAI API Key（备用）
# 申请地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI 兼容接口地址（可选，自定义模型/中转时使用）
# 示例: http://20230620.xyz:3030/v1
OPENAI_BASE_URL=

# OpenAI / 兼容接口的模型名（可选）
OPENAI_MODEL=gpt-4o-mini

# ── 新闻 API ─────────────────────────────────────────────────
# News API（用于实时新闻分析）
# 申请地址: https://newsapi.org/register
NEWS_API_KEY=

# ── 数据库 ───────────────────────────────────────────────────
DB_PASSWORD=changeme_strong_password_123

# ── 管理后台 ─────────────────────────────────────────────────
# /admin 及 /api/admin/* 使用的口令（请求头 X-Admin-Token）
# 生产环境务必修改为强口令
ADMIN_PASSWORD=change_me_strong_admin_password

# ── 域名配置（部署后填写）────────────────────────────────────
DOMAIN=your-domain.com
